{
  "name": "daily",
  "version": "1.0.3",
  "description": "每日工作时间记录与统计桌面应用",
  "main": "electron-main.js",
  "scripts": {
    "build:mac": "electron-builder --mac dir",
    "build:win": "electron-builder --win portable --x64",
    "desktop": "electron .",
    "test": "node tests/smoke.js"
  },
  "keywords": [],
  "author": "zhangmeng",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.zhangmeng.daily-work",
    "productName": "每日工作记录",
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "lucide-local.js",
      "electron-main.js",
      "preload.js"
    ],
    "mac": {
      "target": [
        "dir"
      ]
    },
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "每日工作记录.exe"
    }
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "playwright": "^1.60.0"
  }
}
